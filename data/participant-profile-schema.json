{
  "version": "1.6.0",
  "build": 12,
  "scope": "arkansas",
  "description": "Arkansas participant profile — county-centric civic education ladder",
  "civic_growth_ladder": {
    "title": "Arkansas Education Ladder",
    "levels": [
      "visitor",
      "subscriber",
      "community_supporter",
      "educator",
      "county_leader",
      "ar_research_contributor",
      "education_council"
    ],
    "tracker": "/js/civic-profile.js",
    "constitution": "/docs/CIVIC_PARTICIPATION_CONSTITUTION.md"
  },
  "fields": {
    "participant_id": { "type": "string", "generated": true },
    "civic_growth_level": {
      "type": "string",
      "enum": ["visitor", "subscriber", "community_supporter", "educator", "county_leader", "ar_research_contributor", "education_council"],
      "default": "visitor"
    },
    "civic_growth_level_number": { "type": "integer", "min": 1, "max": 7 },
    "contact": {
      "name": "string",
      "email": "string",
      "phone": "string",
      "city": "string",
      "county": "string",
      "state": { "type": "string", "default": "Arkansas" },
      "zip": "string"
    },
    "learning_progress": {
      "halls_visited": ["string"],
      "depth_levels_used": ["L1", "L2", "L3", "L4"],
      "topics_completed": ["string"],
      "journey_stage": "string"
    },
    "interests": {
      "topics": ["string"],
      "leadership_roles": ["string"],
      "volunteer_roles": ["string"],
      "community_interests": ["string"]
    },
    "organizing": {
      "referrals_made": "number",
      "referral_code": "string",
      "invitations_shared": "number",
      "events_attended": ["string"],
      "conversations_hosted": ["string"],
      "toolkit_downloads": ["string"]
    },
    "solutions": {
      "legislative_ideas_submitted": ["object"],
      "ballot_contributions": ["object"],
      "community_ideas": ["object"],
      "official_resource_shares": ["object"]
    },
    "research_contributions": {
      "sources_submitted": ["string"],
      "reviews_completed": ["string"],
      "arkansas_developments": ["string"]
    }
  }
}
