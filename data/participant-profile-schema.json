{
  "version": "1.5.0",
  "build": 12,
  "description": "Unified participant profile — Civic Growth Ladder v1.0",
  "civic_growth_ladder": {
    "levels": ["visitor", "subscriber", "advocate", "educator", "regional_leader", "research_contributor", "national_leader"],
    "tracker": "/js/civic-profile.js",
    "constitution": "/docs/CIVIC_PARTICIPATION_CONSTITUTION.md"
  },
  "fields": {
    "participant_id": { "type": "string", "generated": true },
