  "relationship_standards": {
    "title": "Institutional Relationship Verbs",
    "principle": "Relationships never hardcoded \u2014 structured data only",
    "verbs": [
      {
        "verb": "SUPPORTED_BY",
        "description": "Claim or assertion backed by source/evidence"
      },
      {
        "verb": "RELATED_TO",
        "description": "General associative link between objects"
      },
      {
        "verb": "PRECEDES",
        "description": "Temporal ordering \u2014 earlier object"
      },
      {
        "verb": "FOLLOWS",
        "description": "Temporal ordering \u2014 later object"
      },
      {
        "verb": "LOCATED_IN",
        "description": "Geographic containment"
      },
      {
        "verb": "MENTORS",
        "description": "Person guides another person"
      },
      {
        "verb": "USES",
        "description": "Object employs another object (e.g. presentation uses video)"
      },
      {
        "verb": "PART_OF",
        "description": "Hierarchical membership"
      },
      {
        "verb": "CITED_BY",
        "description": "Citation inbound reference"
      },
      {
        "verb": "REFERRED_TO",
        "description": "Outbound reference link"
      }
