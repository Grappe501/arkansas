{
  "version": "1.1",
  "build": 14,
  "acucos": "1.0",
  "updated": "2026-07-09",
  "title": "ACUCOS Organization Profile",
  "scope": "arkansas",
  "description": "Schema for organizational profiles in the Arkansas Citizens United Coalition Operating System.",
  "required": ["organization_name", "coalition_category", "city", "county", "state", "participation_level", "contact_email"],
  "fields": {
    "organization_name": { "type": "string", "public_default": true },
    "coalition_category": { "type": "enum", "values_ref": "coalition-ecosystem.coalition_categories", "public_default": true },
    "organization_type": { "type": "string", "deprecated": "Use coalition_category", "public_default": true },
    "city": { "type": "string", "public_default": true },
    "county": { "type": "string", "public_default": true },
    "state": { "type": "string", "default": "Arkansas", "public_default": true },
    "mission_statement": { "type": "text", "public_default": true },
    "website": { "type": "url", "public_default": true },
    "primary_contact": { "type": "string", "public_default": false },
    "secondary_contact": { "type": "string", "public_default": false },
    "contact_email": { "type": "email", "public_default": false },
    "contact_phone": { "type": "string", "public_default": false },
    "areas_of_interest": { "type": "string[]", "public_default": true },
    "resources_requested": { "type": "string[]", "public_default": true },
    "events_hosted": { "type": "number", "public_default": true },
    "participation_level": {
      "type": "enum",
      "values": ["observer", "supporter", "educational_partner", "event_partner", "research_partner", "strategic_partner"],
      "public_default": true
    },
    "partnership_level": { "type": "string", "deprecated": "Use participation_level" },
    "date_joined": { "type": "date", "public_default": true },
    "status": { "type": "enum", "values": ["pending", "active", "inactive"], "public_default": true },
    "privacy": { "type": "object", "description": "Per-field public/private overrides" },
    "referral_source": { "type": "string", "public_default": false }
  },
  "participation_levels_ref": "/data/coalition-ecosystem.json#participation_levels",
  "client_tracker": "/js/coalition-profile.js",
  "form_route": "/coalition/join.html"
}
